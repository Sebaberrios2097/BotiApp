@model Infraestructura.Entities.BotiApp.ProProveedores
<form id="formEditar">
    @Html.AntiForgeryToken()
    <input type="hidden" name="IdProveedor" value="@Model.IdProveedor" />
    <input type="hidden" name="Estado" value="@Model.Estado.ToString().ToLower()" />
    <div style="padding:1.5rem; border-bottom:1px solid #f0ebe5; display:flex; align-items:center; justify-content:space-between;">
        <h2 style="font-size:1.1rem; font-weight:700; color:var(--color-secundario); margin:0;">Editar Proveedor</h2>
        <button type="button" onclick="cerrarOverlay('overlayEditar')" style="background:none; border:none; cursor:pointer; color:#9a8070; font-size:1.4rem; line-height:1;">×</button>
    </div>
    <div style="padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">
        <div>
            <label style="font-size:.84rem; font-weight:600; color:#6b5a4e; display:block; margin-bottom:.35rem;">Nombre del proveedor <span style="color:#dc2626">*</span></label>
            <input name="NombreProveedor" value="@Model.NombreProveedor" maxlength="150" required
                   style="width:100%; padding:.55rem .85rem; border:1.5px solid #e8ddd4; border-radius:8px; font-size:.9rem; outline:none;" />
        </div>
        <div>
            <label style="font-size:.84rem; font-weight:600; color:#6b5a4e; display:block; margin-bottom:.35rem;">Descripción</label>
            <textarea name="DescripcionProveedor" maxlength="300" rows="3"
                      style="width:100%; padding:.55rem .85rem; border:1.5px solid #e8ddd4; border-radius:8px; font-size:.9rem; outline:none; resize:vertical;">@Model.DescripcionProveedor</textarea>
        </div>

        <div id="erroresEditar" style="color:#dc2626; font-size:.82rem; display:none;"></div>
    </div>
    <div style="padding:1rem 1.5rem; border-top:1px solid #f0ebe5; display:flex; justify-content:flex-end; gap:.75rem;">
        <button type="button" onclick="cerrarOverlay('overlayEditar')"
                style="padding:.55rem 1.2rem; border:1.5px solid #e8ddd4; border-radius:8px; background:#fff; font-size:.88rem; font-weight:600; cursor:pointer; color:var(--color-secundario);">
            Cancelar
        </button>
        <button type="submit"
                style="padding:.55rem 1.2rem; background:var(--color-primario); color:#fff; border:none; border-radius:8px; font-size:.88rem; font-weight:600; cursor:pointer;">
            Guardar Cambios
        </button>
    </div>
</form>

