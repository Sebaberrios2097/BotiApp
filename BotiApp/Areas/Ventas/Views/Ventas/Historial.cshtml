@using System.Text.Json
@model BotiApp.Areas.Ventas.Models.HistorialVentasViewModel
@{
    ViewData["Title"] = "Historial de Ventas";

    var boletasJson = JsonSerializer.Serialize(Model.Boletas.Select(b => new
    {
        id         = b.IdBoleta,
        fecha      = b.FechaEmision,
        estado     = b.Estado,
        idEstado   = b.IdEstado,
        idVendedor = b.IdVendedor,
        vendedor   = b.Vendedor,
        idCajero   = b.IdCajero,
        cajero     = b.Cajero,
        total      = b.MontoTotal,
        detalle    = b.Detalle.Select(d => new
        {
            nombre         = d.Nombre,
            cantidad       = d.Cantidad,
            precioUnitario = d.PrecioUnitario,
            precioNormal   = d.PrecioNormal,
            subtotal       = d.Subtotal,
            nombrePromocion = d.NombrePromocion,
            nombreOferta    = d.NombreOferta
        })
    }));

    var vendedoresJson = JsonSerializer.Serialize(Model.Vendedores.Select(v => new
    {
        id     = v.IdUsuario,
        nombre = v.Nombre
    }));
}

<style>
/* ══════════════════════════════════════════════════════
   HEADER CARD
══════════════════════════════════════════════════════ */
.page-header-card { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(44,29,13,.07); padding:1.1rem 1.5rem; margin-bottom:1.4rem; display:flex; align-items:center; gap:1rem; }
.phc-icon { width:46px; height:46px; background:rgba(231,111,46,.1); border-radius:11px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.phc-icon svg { width:24px; height:24px; fill:var(--color-primario); }
.phc-title { font-size:1.15rem; font-weight:700; color:var(--color-secundario); margin:0 0 .15rem; }
.phc-sub { font-size:.8rem; color:#a89080; margin:0; }
.phc-badges { margin-left:auto; display:flex; gap:.5rem; flex-shrink:0; flex-wrap:wrap; }
.phc-badge { display:flex; align-items:center; gap:.35rem; padding:.35rem .75rem; border-radius:20px; font-size:.75rem; font-weight:700; }
.phc-badge.verde   { background:rgba(34,197,94,.1);   color:#16a34a; }
.phc-badge.naranja { background:rgba(231,111,46,.1);  color:var(--color-primario); }
.phc-badge.azul    { background:rgba(99,102,241,.1);  color:#4f46e5; }
.phc-badge svg { width:13px; height:13px; fill:currentColor; }

/* ══════════════════════════════════════════════════════
   PANEL PRINCIPAL
══════════════════════════════════════════════════════ */
.hist-panel { background:#fff; border-radius:14px; box-shadow:0 2px 12px rgba(44,29,13,.07); overflow:hidden; display:flex; flex-direction:column; }
.hist-panel-header { display:flex; align-items:center; gap:.55rem; padding:.85rem 1.15rem; background:var(--color-secundario); color:#fff; flex-shrink:0; }
.hist-panel-header svg { width:17px; height:17px; fill:var(--color-primario); }
.hist-panel-header span { font-size:.85rem; font-weight:700; }
.hist-panel-header .cnt-badge { margin-left:auto; background:var(--color-primario); color:#fff; border-radius:20px; padding:.1rem .55rem; font-size:.7rem; font-weight:700; }

/* ══════════════════════════════════════════════════════
   FILTROS
══════════════════════════════════════════════════════ */
.filtros-wrap { padding:.85rem 1rem; border-bottom:1px solid #f0ebe5; background:#faf7f5; display:flex; flex-direction:column; gap:.65rem; flex-shrink:0; }
.search-bar { display:flex; align-items:center; gap:.5rem; background:#fff; border:1.5px solid #e0d5cc; border-radius:8px; padding:.45rem .8rem; }
.search-bar svg { width:16px; height:16px; fill:var(--color-primario); opacity:.7; flex-shrink:0; }
.search-bar input { border:none; outline:none; font-size:.88rem; width:100%; background:transparent; color:var(--color-secundario); }
.search-bar .clr { background:none; border:none; cursor:pointer; color:#c9b8a8; font-size:1rem; display:none; flex-shrink:0; line-height:1; }
.search-bar .clr.on { display:block; }
.pills-row { display:flex; flex-wrap:wrap; gap:.35rem; }
.pill { padding:.3rem .75rem; border-radius:20px; font-size:.75rem; font-weight:600; border:1.5px solid #e0d5cc; background:#fff; color:#7a6050; cursor:pointer; transition:border-color .15s,background .15s,color .15s; white-space:nowrap; }
.pill:hover { border-color:var(--color-primario); color:var(--color-primario); }
.pill.active { background:var(--color-primario); border-color:var(--color-primario); color:#fff; }

/* ══════════════════════════════════════════════════════
   LISTA DE BOLETAS
══════════════════════════════════════════════════════ */
.boletas-list { padding:.75rem 1rem; display:flex; flex-direction:column; gap:.55rem; }

/* Card de boleta */
.bl-card { border:1.5px solid #ede5df; border-radius:11px; overflow:hidden; transition:border-color .15s,box-shadow .15s; }
.bl-card:hover { border-color:var(--color-primario); box-shadow:0 2px 10px rgba(231,111,46,.10); }
.bl-card.open { border-color:var(--color-primario); }

.bl-card-top { display:flex; align-items:center; gap:.75rem; padding:.6rem .9rem; cursor:pointer; background:#faf7f5; flex-wrap:wrap; user-select:none; }
.bl-card-top:hover { background:#f5efe9; }

.bl-num { font-size:.85rem; font-weight:700; color:var(--color-secundario); flex-shrink:0; min-width:70px; }
.bl-fecha { font-size:.78rem; color:#7a6050; flex-shrink:0; }
.bl-cajero { font-size:.78rem; color:#7a6050; flex:1; min-width:120px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.bl-cajero strong { color:var(--color-secundario); font-weight:700; }
.bl-estado { font-size:.68rem; font-weight:700; padding:.2rem .55rem; border-radius:20px; flex-shrink:0; }
.bl-estado.est-1 { background:#f0fdf4; color:#16a34a; border:1px solid #bbf7d0; }
.bl-estado.est-2 { background:#fef2f2; color:#dc2626; border:1px solid #fecaca; }
.bl-estado.est-other { background:#f1f5f9; color:#475569; border:1px solid #cbd5e1; }
.bl-total { font-size:.88rem; font-weight:700; color:var(--color-primario); flex-shrink:0; margin-left:auto; }
.bl-chevron { width:18px; height:18px; fill:#c9b8a8; flex-shrink:0; transition:transform .2s; }
.bl-card.open .bl-chevron { transform:rotate(180deg); fill:var(--color-primario); }

/* Detalle expandido */
.bl-detalle { display:none; padding:.5rem .9rem .75rem; border-top:1px solid #f0ebe5; background:#fff; }
.bl-card.open .bl-detalle { display:block; }

.bl-det-table { width:100%; border-collapse:collapse; font-size:.78rem; }
.bl-det-table th { text-align:left; padding:.3rem .5rem; color:#a89080; font-weight:600; border-bottom:1.5px solid #f0ebe5; }
.bl-det-table th:last-child, .bl-det-table td:last-child { text-align:right; }
.bl-det-table td { padding:.3rem .5rem; color:var(--color-secundario); border-bottom:1px solid #f8f4f1; }
.bl-det-table tr:last-child td { border-bottom:none; }
.bl-det-total { display:flex; justify-content:flex-end; gap:.5rem; align-items:center; margin-top:.55rem; padding-top:.45rem; border-top:1.5px solid #f0ebe5; }
.bl-det-total .lbl { font-size:.78rem; color:#a89080; font-weight:600; }
.bl-det-total .val { font-size:.95rem; font-weight:700; color:var(--color-primario); }
.etq-promo  { font-size:.62rem; font-weight:700; background:#fef3c7; color:#d97706; border-radius:4px; padding:.1rem .35rem; vertical-align:middle; white-space:nowrap; }
.etq-oferta { font-size:.62rem; font-weight:700; background:#ede9fe; color:#7c3aed; border-radius:4px; padding:.1rem .35rem; vertical-align:middle; white-space:nowrap; }
.precio-normal-tachado { text-decoration:line-through; color:#b8a898; font-size:.72rem; display:block; line-height:1.2; }
.precio-descuento { color:#16a34a; font-weight:700; }

/* Estado vacío */
.boletas-empty { text-align:center; padding:3.5rem 1rem; color:#b8a898; font-size:.88rem; }
.boletas-empty svg { width:52px; height:52px; fill:#ddd0c4; display:block; margin:0 auto .75rem; }

/* Toast */
.toast-wrap { position:fixed; top:1.25rem; right:1.25rem; z-index:9999; display:flex; flex-direction:column; gap:.5rem; pointer-events:none; }
.toast-msg { display:flex; align-items:center; gap:.6rem; padding:.75rem 1.1rem; border-radius:10px; font-size:.88rem; font-weight:600; box-shadow:0 4px 16px rgba(0,0,0,.12); animation:toastIn .3s ease; }
.toast-msg svg { width:18px; height:18px; fill:currentColor; flex-shrink:0; }
.toast-msg.exito { background:#f0fdf4; color:#16a34a; border-left:4px solid #16a34a; }
.toast-msg.error { background:#fef2f2; color:#dc2626; border-left:4px solid #dc2626; }
@@keyframes toastIn { from{opacity:0;transform:translateX(30px)} to{opacity:1;transform:translateX(0)} }

/* ══════════════════════════════════════════════════════
   REIMPRIMIR
══════════════════════════════════════════════════════ */
.bl-reimprimir { display:inline-flex; align-items:center; gap:.4rem; padding:.38rem .85rem; border-radius:8px; border:1.5px solid var(--color-primario); background:#fff; color:var(--color-primario); font-size:.78rem; font-weight:700; cursor:pointer; transition:background .15s,color .15s; }
.bl-reimprimir:hover { background:var(--color-primario); color:#fff; }
.bl-reimprimir svg { width:15px; height:15px; fill:currentColor; }

/* ══════════════════════════════════════════════════════
   TICKET MODAL
══════════════════════════════════════════════════════ */
.ticket-overlay { position:fixed; inset:0; background:rgba(0,0,0,.55); z-index:10000; display:flex; align-items:center; justify-content:center; animation:fadeInT .2s ease; }
@@keyframes fadeInT { from{opacity:0} to{opacity:1} }
.ticket-wrap { background:#fff; width:300px; max-height:92vh; overflow-y:auto; border-radius:8px; box-shadow:0 8px 32px rgba(0,0,0,.25); display:flex; flex-direction:column; }
.ticket-actions { display:flex; gap:.5rem; padding:.65rem .8rem; border-bottom:1px solid #eee; flex-shrink:0; background:#fff; position:sticky; top:0; z-index:1; }
.ticket-actions button { flex:1; padding:.5rem; border-radius:7px; border:none; font-size:.82rem; font-weight:700; cursor:pointer; transition:opacity .15s; }
.ticket-actions button:hover { opacity:.85; }
.btn-print  { background:var(--color-secundario); color:#fff; }
.btn-cerrar { background:#f0ebe5; color:var(--color-secundario); }
.ticket { font-family:'Courier New', Courier, monospace; font-size:11px; line-height:1.25; padding:.5rem .6rem; color:#000; }
.ticket-hr     { border:none; border-top:1px dashed #555; margin:.25rem 0; }
.ticket-hr-sol { border:none; border-top:1px solid #555;  margin:.25rem 0; }
.ticket-row { display:flex; justify-content:space-between; margin-bottom:1px; }
.ticket-row .tk-l { flex:1; min-width:0; overflow:hidden; text-overflow:clip; }
.ticket-row .tk-r { flex-shrink:0; padding-left:.5rem; text-align:right; }
.ticket-total  { font-size:14px; font-weight:700; }
.ticket-bold   { font-weight:700; }
.ticket-center { text-align:center; }
@@page { size:80mm auto; margin:0; }
@@media print {
    html,body { margin:0 !important; padding:0 !important; background:#fff !important; }
    body > * { display:none !important; }
    .ticket-overlay { display:block !important; position:static !important; background:none !important; inset:auto !important; animation:none !important; }
    .ticket-actions { display:none !important; }
    .ticket-wrap { box-shadow:none !important; border-radius:0 !important; max-height:none !important; overflow:visible !important; width:80mm !important; }
    .ticket { padding:2mm !important; font-size:9pt !important; line-height:1.35 !important; }
}
</style>

<div class="toast-wrap" id="toastWrap"></div>

<div class="page-header-card">
    <div class="phc-icon">
        <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
    </div>
    <div>
        <h1 class="phc-title">Historial de Ventas</h1>
        <p class="phc-sub">Consulta y reimprime boletas registradas</p>
    </div>
    <div class="phc-badges">
        <span class="phc-badge naranja">
            <svg viewBox="0 0 24 24"><path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.95-2.05L6.64 18.36A9 9 0 1 0 13 3zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"/></svg>
            @Model.Boletas.Count() registros
        </span>
    </div>
</div>

<div class="hist-panel">
    <div class="hist-panel-header">
        <svg viewBox="0 0 24 24"><path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.95-2.05L6.64 18.36A9 9 0 1 0 13 3zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"/></svg>
        <span>Ventas registradas</span>
        <span class="cnt-badge" id="cntBoletas">@Model.Boletas.Count()</span>
    </div>

    @if (Model.EsAdmin || Model.Boletas.Any())
    {
        <div class="filtros-wrap">
            <div class="search-bar">
                <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                <input type="text" id="txtBuscar" placeholder="Buscar por N° boleta o cajero…"
                       oninput="aplicarFiltros()" autocomplete="off" />
                <button class="clr" id="btnClr" onclick="limpiarQ()" title="Limpiar">✕</button>
            </div>

            @if (Model.EsAdmin)
            {
                <div class="pills-row" id="pillsVendedores">
                    <button class="pill active" data-vendedor="0" onclick="selVendedor(0)">Todas las ventas</button>
                    <button class="pill" data-vendedor="@Model.IdUsuarioActual" onclick="selVendedor(@Model.IdUsuarioActual)">Mis ventas</button>
                    @foreach (var v in Model.Vendedores.Where(v => v.IdUsuario != Model.IdUsuarioActual))
                    {
                        <button class="pill" data-vendedor="@v.IdUsuario" onclick="selVendedor(@v.IdUsuario)">@v.Nombre</button>
                    }
                </div>
            }
        </div>
    }

    <div class="boletas-list" id="boletasList"></div>
</div>

@section Scripts {
<script>
(function () {

    /* ── Datos ──────────────────────────────────────────────────────────────── */
    const BOLETAS      = @Html.Raw(boletasJson);
    const ES_ADMIN     = @Html.Raw(Model.EsAdmin.ToString().ToLower());
    const ES_CAJERO    = @Html.Raw(Model.EsCajero.ToString().ToLower());
    const ID_USUARIO   = @Model.IdUsuarioActual;

    /* ── Estado ─────────────────────────────────────────────────────────────── */
    let vendedorActivo = 0;   // 0 = todos

    /* ══════════════════════════════════════════════════════════════════════════
       FILTROS
    ══════════════════════════════════════════════════════════════════════════ */
    window.selVendedor = function (id) {
        vendedorActivo = id;
        document.querySelectorAll('#pillsVendedores .pill')
            .forEach(p => p.classList.toggle('active', +p.dataset.vendedor === id));
        aplicarFiltros();
    };

    window.aplicarFiltros = function () {
        const q = (document.getElementById('txtBuscar')?.value ?? '').trim().toLowerCase();
        document.getElementById('btnClr')?.classList.toggle('on', q.length > 0);

        const filtradas = BOLETAS.filter(b => {
            const okVendedor = vendedorActivo === 0 || b.idVendedor === vendedorActivo;
            const okQ = q === ''
                || String(b.id).includes(q)
                || b.vendedor.toLowerCase().includes(q)
                || b.fecha.toLowerCase().includes(q);
            return okVendedor && okQ;
        });

        renderLista(filtradas);
    };

    window.limpiarQ = function () {
        document.getElementById('txtBuscar').value = '';
        aplicarFiltros();
    };

    /* ══════════════════════════════════════════════════════════════════════════
       RENDER LISTA
    ══════════════════════════════════════════════════════════════════════════ */
    function renderLista(lista) {
        const cont = document.getElementById('boletasList');
        document.getElementById('cntBoletas').textContent = lista.length;

        if (!lista.length) {
            cont.innerHTML = `
            <div class="boletas-empty">
                <svg viewBox="0 0 24 24"><path d="M20 6h-2.18c.07-.44.18-.88.18-1.33C18 2.99 16.01 1 13.67 1c-1.32 0-2.4.75-3.17 1.69L10 3.5l-.5-.82C8.73 1.75 7.65 1 6.33 1 4 1 2 2.99 2 5.33c0 .45.1.89.18 1.33H0v2h20V6zm-8.5-.17c.38-.61.96-2.33 2.17-2.33 1 0 1.83.83 1.83 1.83 0 .67-.36 1.15-.88 1.5L12 8.5l-1.62-1.67.12-1zm-3 0L7.88 7.83C7.36 7.48 7 7 7 6.33 7 5.33 7.83 4.5 8.83 4.5c1.21 0 1.79 1.72 2.17 2.33zM4 20c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10H4v10z"/></svg>
                No hay ventas para mostrar
            </div>`;
            return;
        }

        cont.innerHTML = lista.map(b => {
            const estadoClass = b.idEstado === 1 ? 'est-1' : b.idEstado === 2 ? 'est-2' : 'est-other';
            const infoHtml    = ES_ADMIN
                ? `<span class="bl-cajero"><strong>Vendedor:</strong> ${x(b.vendedor)}</span>${b.cajero ? ` <span class="bl-cajero"><strong>Cajero:</strong> ${x(b.cajero)}</span>` : ''}`
                : ES_CAJERO
                    ? `<span class="bl-cajero"><strong>Vendedor:</strong> ${x(b.vendedor)}</span>`
                    : '';
            const detalleRows = b.detalle.map(d => {
                const tieneDescuento = d.precioNormal > d.precioUnitario;
                const badge = d.nombrePromocion
                    ? ` <span class="etq-promo">🏷️ ${x(d.nombrePromocion)}</span>`
                    : d.nombreOferta
                        ? ' <span class="etq-oferta">✦ Oferta</span>'
                        : '';
                const precioHtml = tieneDescuento
                    ? `<span class="precio-normal-tachado">$${fmt(d.precioNormal)}</span><span class="precio-descuento">$${fmt(d.precioUnitario)}</span>`
                    : `$${fmt(d.precioUnitario)}`;
                return `
                <tr>
                    <td>${x(d.nombre)}${badge}</td>
                    <td style="text-align:center;">${d.cantidad}</td>
                    <td style="text-align:right;">${precioHtml}</td>
                    <td>$${fmt(d.subtotal)}</td>
                </tr>`;
            }).join('');

            return `
            <div class="bl-card" id="blc-${b.id}">
                <div class="bl-card-top" onclick="toggleDetalle(${b.id})">
                    <span class="bl-num">N° ${b.id}</span>
                    <span class="bl-fecha">${x(b.fecha)}</span>
                    ${infoHtml}
                    <span class="bl-estado ${estadoClass}">${x(b.estado)}</span>
                    <span class="bl-total">$${fmt(b.total)}</span>
                    <svg class="bl-chevron" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
                </div>
                <div class="bl-detalle">
                    <table class="bl-det-table">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th style="text-align:center;">Cant.</th>
                                <th style="text-align:right;">P. Unit.</th>
                                <th style="text-align:right;">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>${detalleRows}</tbody>
                    </table>
                    <div class="bl-det-total">
                        <span class="lbl">Total pagado</span>
                        <span class="val">$${fmt(b.total)}</span>
                    </div>
                    <div style="display:flex;justify-content:flex-end;margin-top:.55rem;">
                        <button class="bl-reimprimir" onclick="event.stopPropagation();reimprimir(${b.id})">
                            <svg viewBox="0 0 24 24"><path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z"/></svg>
                            Reimprimir boleta
                        </button>
                    </div>
                </div>
            </div>`;
        }).join('');
    }

    /* ══════════════════════════════════════════════════════════════════════════
       TOGGLE DETALLE
    ══════════════════════════════════════════════════════════════════════════ */
    window.toggleDetalle = function (id) {
        const card = document.getElementById(`blc-${id}`);
        if (!card) return;
        card.classList.toggle('open');
    };

    /* ══════════════════════════════════════════════════════════════════════════
       UTILIDADES
    ══════════════════════════════════════════════════════════════════════════ */
    function fmt(n) { return Number(n).toLocaleString('es-CL'); }
    function x(s) {
        return String(s ?? '')
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    /* ══════════════════════════════════════════════════════════════════════════
       REIMPRIMIR
    ══════════════════════════════════════════════════════════════════════════ */
    window.reimprimir = function (id) {
        const b = BOLETAS.find(b => b.id === id);
        if (!b) return;
        mostrarTicketHistorial(b);
    };

    function mostrarTicketHistorial(b) {
        const NOMBRE_LOCAL = 'Botillería Cuatro Ases';
        let lineas = '';

        b.detalle.forEach(d => {
            const esEnvase = d.precioNormal === 0 && !d.nombrePromocion && !d.nombreOferta;
            if (esEnvase) {
                lineas += `
            <div class="ticket-row" style="font-size:10px;">
                <span class="tk-l">Envase: ${x(d.nombre)}</span>
                <span class="tk-r">+$${fmt(d.subtotal)}</span>
            </div>`;
                return;
            }
            const badge = d.nombrePromocion ? ' (promo)' : d.nombreOferta ? ' (oferta)' : '';
            const precioHtml = d.precioNormal > d.precioUnitario
                ? `<span style="text-decoration:line-through;font-size:9px;">$${fmt(d.precioNormal)}</span> $${fmt(d.precioUnitario)}`
                : `$${fmt(d.precioUnitario)}`;
            lineas += `
            <div class="ticket-row">
                <span class="tk-l">${x(d.nombre)}${x(badge)}</span>
                <span class="tk-r">${d.cantidad} x ${precioHtml}</span>
            </div>`;
        });

        const html = `
        <div class="ticket-overlay" id="ticketOverlay">
            <div class="ticket-wrap">
                <div class="ticket-actions">
                    <button class="btn-print" onclick="window.print()">Imprimir</button>
                    <button class="btn-cerrar" onclick="document.getElementById('ticketOverlay').remove()">✕ Cerrar</button>
                </div>
                <div class="ticket">
                    <div class="ticket-center ticket-bold" style="font-size:14px;">${x(NOMBRE_LOCAL)}</div>
                    <div class="ticket-center" style="font-size:10px;">TICKET INTERNO</div>
                    <hr class="ticket-hr-sol">
                    <div class="ticket-row"><span class="tk-l">N° Boleta</span><span class="tk-r ticket-bold">${b.id}</span></div>
                    <div class="ticket-row"><span class="tk-l">Fecha</span><span class="tk-r">${x(b.fecha)}</span></div>
                    <hr class="ticket-hr-sol">
                    <div class="ticket-row ticket-bold"><span class="tk-l">ARTÍCULO</span><span class="tk-r">VALOR</span></div>
                    <hr class="ticket-hr">
                    ${lineas}
                    <hr class="ticket-hr-sol">
                    <div class="ticket-row ticket-total"><span class="tk-l">TOTAL</span><span class="tk-r">$${fmt(b.total)}</span></div>
                    <hr class="ticket-hr">
                    <div class="ticket-center" style="margin-top:.5rem;font-size:10px;">¡Gracias por su compra!</div>
                </div>
            </div>
        </div>`;

        document.getElementById('ticketOverlay')?.remove();
        document.body.insertAdjacentHTML('beforeend', html);
    }

    /* ── Inicializar ────────────────────────────────────────────────────────── */
    aplicarFiltros();

})();
</script>
}
