@using Infraestructura.Entities.BotiApp
@model IEnumerable<ProPromocion>
@{
    ViewData["Title"] = "Catálogo de Promociones";
    var hoy = DateTime.Today;
}

<style>
/* ═══════════════════════════════════════════════════ HEADER */
.cat-header { display:flex; align-items:center; gap:.75rem; margin-bottom:1.4rem; }
.cat-header svg { width:22px; height:22px; fill:var(--color-primario); flex-shrink:0; }
.cat-header h1 { font-size:1.2rem; font-weight:800; color:var(--color-secundario); margin:0; }
.cat-badge-readonly { margin-left:auto; display:inline-flex; align-items:center; gap:.3rem; padding:.28rem .7rem; background:#f0fdf4; color:#16a34a; border:1px solid #bbf7d0; border-radius:20px; font-size:.74rem; font-weight:700; }
.cat-badge-readonly svg { width:13px; height:13px; fill:currentColor; }

/* ═══════════════════════════════════════════════════ TOOLBAR */
.cat-toolbar { display:flex; align-items:center; gap:.65rem; margin-bottom:1.1rem; flex-wrap:wrap; }
.cat-search { flex:1; min-width:200px; max-width:320px; position:relative; }
.cat-search input { width:100%; padding:.5rem .75rem .5rem 2.1rem; border:1.5px solid #e0d5cc; border-radius:9px; font-size:.87rem; color:var(--color-secundario); outline:none; transition:border-color .15s; }
.cat-search input:focus { border-color:var(--color-primario); }
.cat-search svg { position:absolute; left:.6rem; top:50%; transform:translateY(-50%); width:15px; height:15px; fill:#b0a097; pointer-events:none; }
.cat-select { padding:.48rem .7rem; border:1.5px solid #e0d5cc; border-radius:9px; font-size:.85rem; color:var(--color-secundario); background:#fff; outline:none; cursor:pointer; }
.cat-count { font-size:.8rem; color:#a89080; font-weight:600; margin-left:auto; }

/* ═══════════════════════════════════════════════════ GRID */
.promo-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:1rem; }

/* ═══════════════════════════════════════════════════ CARD */
.promo-card { background:#fff; border-radius:12px; border:1.5px solid #ece4dc; overflow:hidden; display:flex; flex-direction:column; transition:box-shadow .2s, border-color .2s; }
.promo-card:hover { box-shadow:0 4px 18px rgba(0,0,0,.1); border-color:#d4bfb0; }
.promo-card.inactiva { opacity:.5; }
.promo-card-header { padding:.8rem 1rem; background:linear-gradient(135deg, var(--color-secundario) 0%, #4a3628 100%); color:#fff; }
.promo-card-nombre { font-size:.95rem; font-weight:800; margin-bottom:.15rem; }
.promo-card-precio { font-size:1.1rem; font-weight:900; color:var(--color-primario); }
.promo-card-body { padding:.75rem 1rem; flex:1; display:flex; flex-direction:column; gap:.4rem; }
.promo-desc { font-size:.82rem; color:#a89080; font-style:italic; }
.promo-fechas { font-size:.77rem; color:#b0a097; }
.promo-badges { display:flex; gap:.35rem; flex-wrap:wrap; margin-top:.25rem; }
.promo-badge { display:inline-flex; align-items:center; gap:.2rem; padding:.18rem .55rem; border-radius:20px; font-size:.72rem; font-weight:700; }
.badge-vigente  { background:#f0fdf4; color:#16a34a; border:1px solid #bbf7d0; }
.badge-vencida  { background:#fef2f2; color:#dc2626; border:1px solid #fecaca; }
.badge-futura   { background:#fefce8; color:#ca8a04; border:1px solid #fef08a; }
.badge-inactiva { background:#f1f5f9; color:#94a3b8; border:1px solid #e2e8f0; }
.promo-productos { margin-top:.5rem; }
.promo-prod-title { font-size:.74rem; font-weight:700; color:#a89080; text-transform:uppercase; letter-spacing:.04em; margin-bottom:.3rem; }
.promo-prod-item { display:flex; align-items:center; gap:.4rem; font-size:.82rem; color:var(--color-secundario); padding:.18rem 0; border-bottom:1px solid #f5f0ea; }
.promo-prod-item:last-child { border-bottom:none; }
.promo-prod-qty { background:var(--color-primario); color:#fff; border-radius:20px; font-size:.7rem; font-weight:700; padding:.05rem .35rem; flex-shrink:0; }
.cat-empty { text-align:center; padding:3rem; color:#a89080; grid-column:1/-1; }
.cat-empty svg { width:52px; height:52px; fill:#ddd0c4; display:block; margin:0 auto .75rem; }
</style>

<div class="cat-header">
    <svg viewBox="0 0 24 24"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
    <h1>Catálogo de Promociones</h1>
    <span class="cat-badge-readonly">
        <svg viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
        Solo lectura
    </span>
</div>

<div class="cat-toolbar">
    <div class="cat-search">
        <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
        <input type="text" id="promoSearch" placeholder="Buscar promoción…" oninput="filtrarPromo()" />
    </div>
    <select class="cat-select" id="promoFiltroVigencia" onchange="filtrarPromo()">
        <option value="">Todas</option>
        <option value="vigente">Vigentes</option>
        <option value="futura">Futuras</option>
        <option value="vencida">Vencidas</option>
        <option value="inactiva">Inactivas</option>
    </select>
    <span class="cat-count" id="promoCount"></span>
</div>

<div class="promo-grid" id="promoGrid">
    @foreach (var p in Model)
    {
        string vigencia;
        if (!p.Estado)
            vigencia = "inactiva";
        else if (p.FechaInicio > hoy)
            vigencia = "futura";
        else if (p.FechaFin.HasValue && p.FechaFin.Value.Date < hoy)
            vigencia = "vencida";
        else
            vigencia = "vigente";

        string badgeClass = vigencia switch {
            "vigente"  => "badge-vigente",
            "futura"   => "badge-futura",
            "vencida"  => "badge-vencida",
            _          => "badge-inactiva"
        };
        string badgeLabel = vigencia switch {
            "vigente"  => "Vigente",
            "futura"   => "Próxima",
            "vencida"  => "Vencida",
            _          => "Inactiva"
        };

        <div class="promo-card @(p.Estado ? "" : "inactiva")"
             data-nombre="@p.Nombre.ToLower()"
             data-vigencia="@vigencia">
            <div class="promo-card-header">
                <div class="promo-card-nombre">@p.Nombre</div>
                <div class="promo-card-precio">$@p.PrecioPromocion.ToString("N0")</div>
            </div>
            <div class="promo-card-body">
                @if (!string.IsNullOrEmpty(p.Descripcion))
                {
                    <div class="promo-desc">@p.Descripcion</div>
                }
                <div class="promo-fechas">
                    Desde @p.FechaInicio.ToString("dd/MM/yyyy")
                    @if (p.FechaFin.HasValue)
                    {
                        <text> hasta @p.FechaFin.Value.ToString("dd/MM/yyyy")</text>
                    }
                    else
                    {
                        <text> (sin fecha fin)</text>
                    }
                </div>
                <div class="promo-badges">
                    <span class="promo-badge @badgeClass">@badgeLabel</span>
                </div>

                @if (p.ProPromocionDetalle.Any())
                {
                    <div class="promo-productos">
                        <div class="promo-prod-title">Productos incluidos</div>
                        @foreach (var d in p.ProPromocionDetalle.Take(5))
                        {
                            <div class="promo-prod-item">
                                <span class="promo-prod-qty">@d.Cantidad</span>
                                <span>@(d.IdProductoNavigation?.NombreProducto ?? "—")</span>
                            </div>
                        }
                        @if (p.ProPromocionDetalle.Count > 5)
                        {
                            <div style="font-size:.75rem;color:#a89080;margin-top:.2rem">
                                +@(p.ProPromocionDetalle.Count - 5) productos más…
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
(function () {
    function filtrarPromo() {
        const texto    = document.getElementById('promoSearch').value.toLowerCase().trim();
        const vigencia = document.getElementById('promoFiltroVigencia').value;
        const cards    = document.querySelectorAll('#promoGrid .promo-card');
        let vis = 0;

        cards.forEach(c => {
            const matchTxt = !texto    || c.dataset.nombre.includes(texto);
            const matchVig = !vigencia || c.dataset.vigencia === vigencia;
            const show = matchTxt && matchVig;
            c.style.display = show ? '' : 'none';
            if (show) vis++;
        });

        document.getElementById('promoCount').textContent =
            `${vis} promoción${vis !== 1 ? 'es' : ''}`;
    }

    window.filtrarPromo = filtrarPromo;
    filtrarPromo();
})();
</script>
}
