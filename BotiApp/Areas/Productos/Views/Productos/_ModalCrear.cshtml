@model Infraestructura.Entities.BotiApp.ProProductos
@{
    var ultimos = ViewBag.UltimosProductos as IEnumerable<Infraestructura.Entities.BotiApp.ProProductos>
                  ?? Enumerable.Empty<Infraestructura.Entities.BotiApp.ProProductos>();
}
<style>
    .mc-header {
        display:flex; align-items:center; justify-content:space-between;
        padding:1.25rem 1.5rem; border-bottom:1px solid #f0ebe5;
        background:var(--color-secundario); border-radius:16px 16px 0 0;
    }
    .mc-header-left { display:flex; align-items:center; gap:.65rem; }
    .mc-header-left svg { width:22px; height:22px; fill:var(--color-primario); }
    .mc-header-left h2 { font-size:1.05rem; font-weight:700; color:#fff; margin:0; }
    .mc-close {
        width:32px; height:32px; border-radius:8px; border:none; cursor:pointer;
        background:rgba(255,255,255,.08); color:rgba(255,255,255,.7);
        display:flex; align-items:center; justify-content:center;
        transition:background .2s;
    }
    .mc-close:hover { background:rgba(255,255,255,.15); color:#fff; }
    .mc-close svg { width:18px; height:18px; fill:currentColor; }

    /* Layout 2 columnas */
    .mc-body {
        display:grid;
        grid-template-columns: 1fr 260px;
    }

    /* Columna principal */
    .mc-main { padding:1.5rem; overflow-y:auto; max-height:72vh; }

    /* Columna aside */
    .mc-aside {
        border-left:1px solid #f0ebe5;
        background:#faf7f5;
        display:flex; flex-direction:column;
        overflow:hidden;
    }
    .mc-aside-header {
        padding:.9rem 1rem;
        border-bottom:1px solid #f0ebe5;
        display:flex; align-items:center; gap:.5rem;
    }
    .mc-aside-header svg { width:15px; height:15px; fill:var(--color-primario); }
    .mc-aside-header span { font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:#7a6050; }
    .mc-aside-body { padding:.75rem; overflow-y:auto; flex:1; display:flex; flex-direction:column; gap:.6rem; }

    /* Tarjeta de producto reciente */
    .recent-card {
        background:#fff; border-radius:8px; padding:.7rem .85rem;
        border:1px solid #ede5df;
        display:flex; align-items:center; gap:.65rem;
        transition:box-shadow .15s;
    }
    .recent-card:hover { box-shadow:0 2px 8px rgba(44,29,13,.08); }
    .recent-card-img {
        width:36px; height:36px; border-radius:6px; object-fit:cover;
        background:#f0ebe5; border:1px solid #e0d5cc; flex-shrink:0;
    }
    .recent-card-img-ph {
        width:36px; height:36px; border-radius:6px; background:#f0ebe5;
        border:1px solid #e0d5cc; flex-shrink:0;
        display:flex; align-items:center; justify-content:center;
    }
    .recent-card-img-ph svg { width:18px; height:18px; fill:#c9b8a8; }
    .recent-card-info { flex:1; min-width:0; }
    .recent-card-name { font-size:.8rem; font-weight:600; color:var(--color-secundario); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .recent-card-meta { font-size:.72rem; color:#a89080; margin-top:.1rem; }
    .recent-card-price { font-size:.8rem; font-weight:700; color:var(--color-primario); white-space:nowrap; }

    .aside-empty { text-align:center; padding:2rem .5rem; color:#b8a898; font-size:.82rem; }

    /* Formulario */
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:.9rem 1.2rem; }
    .form-group { display:flex; flex-direction:column; gap:.3rem; }
    .form-group.full { grid-column:1/-1; }
    .form-label { font-size:.8rem; font-weight:600; color:var(--color-secundario); }
    .form-label .req { color:var(--color-primario); margin-left:2px; }
    .form-control {
        padding:.55rem .8rem; border:1.5px solid #e0d5cc; border-radius:8px;
        font-size:.88rem; color:var(--color-secundario); background:#faf7f5;
        transition:border-color .2s, box-shadow .2s; outline:none; width:100%;
    }
    .form-control:focus { border-color:var(--color-primario); box-shadow:0 0 0 3px rgba(231,111,46,.13); background:#fff; }
    .form-control.input-error { border-color:#dc2626; }
    .field-error { font-size:.76rem; color:#dc2626; }

    .img-drop {
        border:2px dashed #e0d5cc; border-radius:10px; padding:1rem;
        text-align:center; background:#faf7f5; cursor:pointer;
        transition:border-color .2s;
    }
    .img-drop:hover { border-color:var(--color-primario); }
    .img-drop svg { width:30px; height:30px; fill:#c9b8a8; }
    .img-drop p { font-size:.78rem; color:#a89080; margin:.3rem 0 0; }
    #imgPreviewCrear { max-width:100%; max-height:110px; border-radius:8px; margin-top:.6rem; display:none; object-fit:cover; }

    .toggle-w { display:flex; align-items:center; gap:.6rem; padding:.55rem 0; }
    .toggle-sw { position:relative; width:42px; height:23px; flex-shrink:0; }
    .toggle-sw input { opacity:0; width:0; height:0; }
    .toggle-sl { position:absolute; inset:0; background:#ccc; border-radius:24px; cursor:pointer; transition:background .2s; }
    .toggle-sl:before { content:""; position:absolute; width:17px; height:17px; left:3px; top:3px; background:#fff; border-radius:50%; transition:transform .2s; }
    .toggle-sw input:checked + .toggle-sl { background:var(--color-primario); }
    .toggle-sw input:checked + .toggle-sl:before { transform:translateX(19px); }
    .toggle-label { font-size:.86rem; font-weight:600; color:var(--color-secundario); }

    .mc-footer {
        padding:1rem 1.5rem; border-top:1px solid #f0ebe5;
        display:flex; gap:.65rem; background:#fff;
        border-radius:0 0 0 16px;
    }
    .btn-save {
        display:inline-flex; align-items:center; gap:.4rem;
        padding:.58rem 1.3rem; background:var(--color-primario); color:#fff;
        border:none; border-radius:8px; font-size:.88rem; font-weight:600;
        cursor:pointer; transition:background .2s, transform .15s;
    }
    .btn-save svg { width:16px; height:16px; fill:currentColor; }
    .btn-save:hover { background:#cf5f22; transform:translateY(-1px); }
    .btn-cancel {
        display:inline-flex; align-items:center; gap:.4rem;
        padding:.58rem 1.1rem; background:#f0ebe5; color:var(--color-secundario);
        border:none; border-radius:8px; font-size:.88rem; font-weight:600;
        cursor:pointer; transition:background .15s;
    }
    .btn-cancel:hover { background:#e0d5cc; }

    @@media (max-width:650px) {
        .mc-body { grid-template-columns:1fr; }
        .mc-aside { border-left:none; border-top:1px solid #f0ebe5; max-height:200px; }
        .mc-main  { max-height:none; }
        .form-grid { grid-template-columns:1fr; }
        .form-group.full { grid-column:1; }
    }
</style>

<!-- Header -->
<div class="mc-header">
    <div class="mc-header-left">
        <svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
        <h2>Nuevo Producto</h2>
    </div>
    <button class="mc-close" onclick="cerrarModal()" aria-label="Cerrar">
        <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
    </button>
</div>

<div class="mc-body">
    <!-- Formulario principal -->
    <div class="mc-main">
        <form id="formCrear"
              asp-area="Productos" asp-controller="Productos" asp-action="CrearAjax"
              method="post" enctype="multipart/form-data" novalidate
              onsubmit="event.preventDefault(); submitFormAjax('formCrear', true)">
            @Html.AntiForgeryToken()
            <div class="form-grid">

                <div class="form-group">
                    <label class="form-label" asp-for="NombreProducto">Nombre <span class="req">*</span></label>
                    <input asp-for="NombreProducto" class="form-control" placeholder="Ej. Cerveza Kunstmann 500ml" />
                    <span asp-validation-for="NombreProducto" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Codigo">Código / SKU</label>
                    <div style="display:flex;gap:.45rem;align-items:center;">
                        <input asp-for="Codigo" class="form-control" placeholder="Ej. CRV-0012" id="crearCodigo" style="flex:1;min-width:0;" />
                        <button type="button" id="crearBtnScan" onclick="prdToggleScanner('crear')" title="Escanear código de barras"
                            style="flex-shrink:0;width:36px;height:36px;border:1.5px solid #e0d5cc;border-radius:7px;background:#faf7f5;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--color-primario);transition:background .15s;">
                            <svg viewBox="0 0 24 24" style="width:18px;height:18px;fill:currentColor;"><path d="M9 2H4C2.9 2 2 2.9 2 4v5h2V4h5V2zm-5 18v-5H2v5c0 1.1.9 2 2 2h5v-2H4zm16 0h-5v2h5c1.1 0 2-.9 2-2v-5h-2v5zm0-16h-5V2h5c1.1 0 2 .9 2 2v5h-2V4zM7 7h10v10H7z"/></svg>
                        </button>
                    </div>
                    <div id="crearScannerWrap" style="display:none;margin-top:.5rem;border-radius:10px;overflow:hidden;background:#000;position:relative;max-height:200px;">
                        <video id="crearScannerVideo" playsinline muted style="width:100%;max-height:200px;object-fit:cover;display:block;"></video>
                        <div style="position:absolute;inset:0;pointer-events:none;display:flex;align-items:center;justify-content:center;">
                            <div style="width:65%;height:68px;border-radius:7px;border:2.5px solid rgba(231,111,46,.95);box-shadow:0 0 0 9999px rgba(0,0,0,.45);"></div>
                        </div>
                        <button type="button" onclick="prdDetenerScanner('crear')" aria-label="Cerrar escáner"
                            style="position:absolute;top:.4rem;right:.4rem;width:26px;height:26px;border-radius:50%;border:none;cursor:pointer;background:rgba(255,255,255,.15);color:#fff;display:flex;align-items:center;justify-content:center;">
                            <svg viewBox="0 0 24 24" style="width:14px;height:14px;fill:currentColor;"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                        </button>
                        <p style="color:rgba(255,255,255,.6);font-size:.7rem;text-align:center;margin:.35rem 0;padding:0;">Apunta al código de barras</p>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="IdTipoProducto">Tipo <span class="req">*</span></label>
                    <select asp-for="IdTipoProducto" asp-items="ViewBag.Tipos" class="form-control">
                        <option value="">— Selecciona —</option>
                    </select>
                    <span asp-validation-for="IdTipoProducto" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="IdMarca">Marca <span class="req">*</span></label>
                    <select asp-for="IdMarca" asp-items="ViewBag.Marcas" class="form-control">
                        <option value="">— Selecciona —</option>
                    </select>
                    <span asp-validation-for="IdMarca" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Precio">Precio ($) <span class="req">*</span></label>
                    <input asp-for="Precio" type="number" min="0" class="form-control" placeholder="0" />
                    <span asp-validation-for="Precio" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Stock">Stock <span class="req">*</span></label>
                    <input asp-for="Stock" type="number" min="0" class="form-control" placeholder="0" />
                    <span asp-validation-for="Stock" class="field-error"></span>
                </div>

                <div class="form-group full">
                    <label class="form-label" asp-for="Descripción">Descripción</label>
                    <textarea asp-for="Descripción" class="form-control" rows="2" placeholder="Descripción breve…"></textarea>
                </div>

                <div class="form-group full">
                    <label class="form-label">Imagen</label>
                    <div class="img-drop" onclick="document.getElementById('imgFileCrear').click()">
                        <svg viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                        <p>Clic para seleccionar imagen (JPG, PNG)</p>
                    </div>
                    <input type="file" id="imgFileCrear" name="imagenFile" accept="image/*"
                           style="display:none" onchange="prevImg(this,'imgPreviewCrear')" />
                    <img id="imgPreviewCrear" alt="Vista previa" />
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Estado">Estado</label>
                    <div class="toggle-w">
                        <label class="toggle-sw">
                            <input asp-for="Estado" type="checkbox" />
                            <span class="toggle-sl"></span>
                        </label>
                        <span class="toggle-label">Activo</span>
                    </div>
                </div>

            </div>
        </form>
    </div>

    <!-- Aside: últimos incorporados -->
    <aside class="mc-aside">
        <div class="mc-aside-header">
            <svg viewBox="0 0 24 24"><path d="M13 3a9 9 0 1 0 0 18A9 9 0 0 0 13 3zm0 16c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7zm.5-11H12v6l5.25 3.15.75-1.23-4.5-2.67V8z"/></svg>
            <span>Incorporados recientemente</span>
        </div>
        <div class="mc-aside-body">
            @if (!ultimos.Any())
            {
                <div class="aside-empty">Sin productos aún</div>
            }
            else
            {
                foreach (var u in ultimos)
                {
                    <div class="recent-card">
                        @if (u.Imagen is { Length: > 0 })
                        {
                            <img class="recent-card-img"
                                 src="/Productos/Productos/Imagen/@u.IdProducto"
                                 alt="@u.NombreProducto" />
                        }
                        else
                        {
                            <div class="recent-card-img-ph">
                                <svg viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                            </div>
                        }
                        <div class="recent-card-info">
                            <div class="recent-card-name">@u.NombreProducto</div>
                            <div class="recent-card-meta">@(u.IdMarcaNavigation?.NombreMarca ?? "—") · @u.FechaIngreso.ToString("dd/MM/yy")</div>
                        </div>
                        <div class="recent-card-price">$@u.Precio.ToString("N0")</div>
                    </div>
                }
            }
        </div>
    </aside>
</div>

<!-- Footer -->
<div class="mc-footer">
    <button type="submit" form="formCrear" class="btn-save">
        <svg viewBox="0 0 24 24"><path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/></svg>
        Guardar producto
    </button>
    <button type="button" class="btn-cancel" onclick="cerrarModal()">Cancelar</button>
</div>

<script>
function prevImg(input, previewId) {
    const preview = document.getElementById(previewId);
    if (input.files?.[0]) {
        const reader = new FileReader();
        reader.onload = e => { preview.src = e.target.result; preview.style.display = 'block'; };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
