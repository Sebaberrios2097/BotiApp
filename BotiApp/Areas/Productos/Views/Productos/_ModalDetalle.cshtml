@model Infraestructura.Entities.BotiApp.ProProductos
@{
    var auditoria = ViewBag.Auditoria as IEnumerable<Infraestructura.Entities.BotiApp.AudProProductos>
                    ?? Enumerable.Empty<Infraestructura.Entities.BotiApp.AudProProductos>();
}
<style>
    .md-header {
        display:flex; align-items:center; justify-content:space-between;
        padding:1.25rem 1.5rem; border-bottom:1px solid #f0ebe5;
        background:var(--color-secundario); border-radius:16px 16px 0 0;
    }
    .md-header-left { display:flex; align-items:center; gap:.65rem; }
    .md-header-left svg { width:22px; height:22px; fill:var(--color-primario); }
    .md-header-left h2 { font-size:1.05rem; font-weight:700; color:#fff; margin:0; }
    .md-close { width:32px; height:32px; border-radius:8px; border:none; cursor:pointer; background:rgba(255,255,255,.08); color:rgba(255,255,255,.7); display:flex; align-items:center; justify-content:center; transition:background .2s; }
    .md-close:hover { background:rgba(255,255,255,.15); color:#fff; }
    .md-close svg { width:18px; height:18px; fill:currentColor; }

    .md-body { display:grid; grid-template-columns:1fr 260px; }

    /* Contenido detalle */
    .md-main { padding:1.5rem; overflow-y:auto; max-height:72vh; }

    .det-top { display:flex; gap:1.25rem; margin-bottom:1.5rem; align-items:flex-start; }
    .det-img { width:110px; height:110px; border-radius:12px; object-fit:cover; border:2px solid #e8ddd4; flex-shrink:0; }
    .det-img-ph { width:110px; height:110px; border-radius:12px; background:#f5f0eb; border:2px solid #e8ddd4; flex-shrink:0; display:flex; align-items:center; justify-content:center; }
    .det-img-ph svg { width:42px; height:42px; fill:#c9b8a8; }

    .det-headline h3 { font-size:1.15rem; font-weight:700; color:var(--color-secundario); margin:0 0 .35rem; }
    .det-headline .badge { display:inline-flex; padding:.25rem .7rem; border-radius:20px; font-size:.75rem; font-weight:700; }
    .det-headline .badge.activo   { background:rgba(34,197,94,.12); color:#16a34a; }
    .det-headline .badge.inactivo { background:rgba(239,68,68,.10); color:#dc2626; }
    .det-kpis { display:flex; gap:1rem; margin-top:.75rem; flex-wrap:wrap; }
    .det-kpi  { display:flex; flex-direction:column; }
    .det-kpi .kpi-label { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#a89080; }
    .det-kpi .kpi-val   { font-size:1rem; font-weight:700; color:var(--color-secundario); }
    .det-kpi .kpi-val.precio { color:var(--color-primario); font-size:1.1rem; }
    .det-kpi .kpi-val.stock-bajo { color:#dc2626; }
    .det-kpi .kpi-val.stock-ok   { color:#16a34a; }

    .det-divider { height:1px; background:#f0ebe5; margin:1.1rem 0; }

    .det-grid { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; }
    .det-field .df-label { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#a89080; margin-bottom:.2rem; }
    .det-field .df-value { font-size:.9rem; font-weight:500; color:var(--color-secundario); }
    .det-field.full { grid-column:1/-1; }
    .det-field .df-desc { font-size:.86rem; color:var(--color-secundario); line-height:1.55; }

    /* Aside (mismo estilo que editar) */
    .md-aside { border-left:1px solid #f0ebe5; background:#faf7f5; display:flex; flex-direction:column; overflow:hidden; }
    .md-aside-header { padding:.9rem 1rem; border-bottom:1px solid #f0ebe5; display:flex; align-items:center; gap:.5rem; }
    .md-aside-header svg { width:15px; height:15px; fill:var(--color-primario); }
    .md-aside-header span { font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:#7a6050; }
    .md-aside-body { padding:.75rem 1rem; overflow-y:auto; flex:1; }

    .audit-timeline { position:relative; }
    .audit-timeline::before { content:""; position:absolute; left:11px; top:0; bottom:0; width:2px; background:#e8ddd4; }
    .audit-item { display:flex; gap:.75rem; margin-bottom:1rem; position:relative; }
    .audit-dot { width:24px; height:24px; border-radius:50%; flex-shrink:0; background:var(--color-primario); display:flex; align-items:center; justify-content:center; z-index:1; }
    .audit-dot svg { width:12px; height:12px; fill:#fff; }
    .audit-info { flex:1; min-width:0; }
    .audit-motivo { font-size:.8rem; font-weight:600; color:var(--color-secundario); line-height:1.3; }
    .audit-fecha  { font-size:.72rem; color:#a89080; margin-top:.15rem; }
    .audit-chips  { display:flex; flex-wrap:wrap; gap:.3rem; margin-top:.35rem; }
    .audit-chip { padding:.15rem .5rem; border-radius:20px; font-size:.7rem; font-weight:600; background:rgba(231,111,46,.1); color:var(--color-primario); }
    .audit-chip.estado-on  { background:rgba(34,197,94,.1); color:#16a34a; }
    .audit-chip.estado-off { background:rgba(239,68,68,.1); color:#dc2626; }
    .aside-empty { text-align:center; padding:2rem .5rem; color:#b8a898; font-size:.82rem; }
    .aside-empty svg { width:32px; height:32px; fill:#ddd0c4; display:block; margin:0 auto .5rem; }

    /* Footer */
    .md-footer {
        padding:1rem 1.5rem; border-top:1px solid #f0ebe5;
        display:flex; gap:.65rem; background:#fff; border-radius:0 0 0 16px;
    }
    .btn-edit { display:inline-flex; align-items:center; gap:.4rem; padding:.58rem 1.3rem; background:var(--color-primario); color:#fff; border:none; border-radius:8px; font-size:.88rem; font-weight:600; cursor:pointer; transition:background .2s, transform .15s; }
    .btn-edit svg { width:16px; height:16px; fill:currentColor; }
    .btn-edit:hover { background:#cf5f22; transform:translateY(-1px); }
    .btn-close-det { display:inline-flex; align-items:center; gap:.4rem; padding:.58rem 1.1rem; background:#f0ebe5; color:var(--color-secundario); border:none; border-radius:8px; font-size:.88rem; font-weight:600; cursor:pointer; transition:background .15s; }
    .btn-close-det:hover { background:#e0d5cc; }

    @@media (max-width:650px) {
        .md-body  { grid-template-columns:1fr; }
        .md-aside { border-left:none; border-top:1px solid #f0ebe5; max-height:180px; }
        .md-main  { max-height:none; }
        .det-grid { grid-template-columns:1fr; }
        .det-field.full { grid-column:1; }
    }
</style>

<!-- Header -->
<div class="md-header">
    <div class="md-header-left">
        <svg viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
        <h2>Detalle del Producto</h2>
    </div>
    <button class="md-close" onclick="cerrarModal()" aria-label="Cerrar">
        <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
    </button>
</div>

<div class="md-body">

    <!-- Detalle principal -->
    <div class="md-main">

        <div class="det-top">
            @if (Model.Imagen is { Length: > 0 })
            {
                <img class="det-img" src="/Productos/Productos/Imagen/@Model.IdProducto" alt="@Model.NombreProducto" />
            }
            else
            {
                <div class="det-img-ph">
                    <svg viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                </div>
            }
            <div class="det-headline">
                <h3>@Model.NombreProducto</h3>
                <span class="badge @(Model.Estado ? "activo" : "inactivo")">@(Model.Estado ? "Activo" : "Inactivo")</span>
                <div class="det-kpis">
                    <div class="det-kpi">
                        <span class="kpi-label">Precio</span>
                        <span class="kpi-val precio">$@Model.Precio.ToString("N0")</span>
                    </div>
                    <div class="det-kpi">
                        <span class="kpi-label">Stock</span>
                        <span class="kpi-val @(Model.Stock <= 5 ? "stock-bajo" : "stock-ok")">@Model.Stock uds.</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="det-divider"></div>

        <div class="det-grid">
            <div class="det-field">
                <div class="df-label">Marca</div>
                <div class="df-value">@(Model.IdMarcaNavigation?.NombreMarca ?? "—")</div>
            </div>
            <div class="det-field">
                <div class="df-label">Tipo</div>
                <div class="df-value">@(Model.IdTipoProductoNavigation?.NombreTipoProducto ?? "—")</div>
            </div>
            <div class="det-field">
                <div class="df-label">Código / SKU</div>
                <div class="df-value">@(string.IsNullOrWhiteSpace(Model.Codigo) ? "—" : Model.Codigo)</div>
            </div>
            <div class="det-field">
                <div class="df-label">Fecha de ingreso</div>
                <div class="df-value">@Model.FechaIngreso.ToString("dd/MM/yyyy")</div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Descripción))
            {
                <div class="det-field full">
                    <div class="df-label">Descripción</div>
                    <div class="df-desc">@Model.Descripción</div>
                </div>
            }
        </div>
    </div>

    <!-- Aside: historial -->
    <aside class="md-aside">
        <div class="md-aside-header">
            <svg viewBox="0 0 24 24"><path d="M13 3a9 9 0 1 0 0 18A9 9 0 0 0 13 3zm0 16c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7zm.5-11H12v6l5.25 3.15.75-1.23-4.5-2.67V8z"/></svg>
            <span>Historial de cambios</span>
        </div>
        <div class="md-aside-body">
            @if (!auditoria.Any())
            {
                <div class="aside-empty">
                    <svg viewBox="0 0 24 24"><path d="M13 3a9 9 0 1 0 0 18A9 9 0 0 0 13 3zm0 16c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7zm.5-11H12v6l5.25 3.15.75-1.23-4.5-2.67V8z"/></svg>
                    Sin modificaciones registradas
                </div>
            }
            else
            {
                <div class="audit-timeline">
                    @foreach (var a in auditoria)
                    {
                        <div class="audit-item">
                            <div class="audit-dot">
                                <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z"/></svg>
                            </div>
                            <div class="audit-info">
                                <div class="audit-motivo">@a.Motivo</div>
                                <div class="audit-fecha">@a.FechaModificacion.ToString("dd/MM/yyyy HH:mm")</div>
                                <div class="audit-chips">
                                    <span class="audit-chip">$@a.Precio.ToString("N0")</span>
                                    <span class="audit-chip @(a.Estado ? "estado-on" : "estado-off")">
                                        @(a.Estado ? "Activo" : "Inactivo")
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </aside>
</div>

<!-- Footer -->
<div class="md-footer">
    <button class="btn-edit"
            onclick="cerrarModal(); setTimeout(() => abrirModal('/Productos/Productos/ModalEditar/@Model.IdProducto'), 260)">
        <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
        Editar producto
    </button>
    <button class="btn-close-det" onclick="cerrarModal()">Cerrar</button>
</div>