<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BotiApp</title>
    <link rel="stylesheet" href="~/css/colores.css" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                background-color: var(--color-primario);
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            .login-wrapper {
                display: flex;
                width: 100%;
                max-width: 900px;
                min-height: 520px;
                border-radius: 20px;
                overflow: hidden;
                box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
                margin: 1rem;
            }

            .login-brand {
                flex: 1;
                background-color: var(--color-secundario);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                padding: 2.5rem;
                gap: 1.25rem;
            }

                .login-brand .brand-icon {
                    width: 72px;
                    height: 72px;
                    background-color: var(--color-primario);
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                    .login-brand .brand-icon svg {
                        width: 38px;
                        height: 38px;
                        fill: var(--blanco);
                    }

                .login-brand h1 {
                    color: var(--blanco);
                    font-size: 1.8rem;
                    font-weight: 700;
                    letter-spacing: 1px;
                    text-align: center;
                }

                .login-brand p {
                    color: var(--color-primario);
                    font-size: 0.95rem;
                    text-align: center;
                    opacity: 0.9;
                }

            .login-card {
                flex: 1;
                background-color: var(--blanco);
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 3rem 2.5rem;
                gap: 1.5rem;
            }

                .login-card h2 {
                    color: var(--color-secundario);
                    font-size: 1.6rem;
                    font-weight: 700;
                }

                .login-card p.subtitle {
                    color: var(--color-secundario);
                    font-size: 0.9rem;
                    opacity: 0.6;
                    margin-top: -1rem;
                }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: 0.4rem;
            }

                .form-group label {
                    font-size: 0.85rem;
                    font-weight: 600;
                    color: var(--color-secundario);
                    letter-spacing: 0.5px;
                }

            .input-wrapper {
                position: relative;
                display: flex;
                align-items: center;
            }

                .input-wrapper svg {
                    position: absolute;
                    left: 0.9rem;
                    width: 18px;
                    height: 18px;
                    fill: var(--color-primario);
                    pointer-events: none;
                }

            .form-group input {
                width: 100%;
                padding: 0.75rem 1rem 0.75rem 2.7rem;
                border: 2px solid #e0d5cc;
                border-radius: 10px;
                font-size: 0.95rem;
                background-color: var(--blanco);
                color: var(--color-secundario);
                outline: none;
                transition: border-color 0.25s, box-shadow 0.25s;
            }

                .form-group input:focus {
                    border-color: var(--color-primario);
                    box-shadow: 0 0 0 3px rgba(231, 111, 46, 0.18);
                }

                .form-group input::placeholder {
                    color: #aaa;
                }

            .form-options {
                display: flex;
                align-items: center;
                justify-content: space-between;
                font-size: 0.85rem;
            }

                .form-options label {
                    display: flex;
                    align-items: center;
                    gap: 0.4rem;
                    color: var(--color-secundario);
                    cursor: pointer;
                    font-weight: 500;
                }

                .form-options input[type="checkbox"] {
                    accent-color: var(--color-primario);
                    width: 16px;
                    height: 16px;
                }

                .form-options a {
                    color: var(--color-primario);
                    text-decoration: none;
                    font-weight: 600;
                }

                    .form-options a:hover {
                        text-decoration: underline;
                    }

            .btn-login {
                padding: 0.85rem;
                background-color: var(--color-primario);
                color: var(--blanco);
                border: none;
                border-radius: 10px;
                font-size: 1rem;
                font-weight: 700;
                cursor: pointer;
                letter-spacing: 0.5px;
                transition: background-color 0.25s, transform 0.15s, box-shadow 0.25s;
                box-shadow: 0 4px 14px rgba(231, 111, 46, 0.4);
            }

                .btn-login:hover {
                    background-color: #cf5f22;
                    transform: translateY(-1px);
                    box-shadow: 0 6px 18px rgba(231, 111, 46, 0.5);
                }

                .btn-login:active {
                    transform: translateY(0);
                }

            @@media (max-width: 620px) {
                .login-brand {
                    display: none;
                }

                .login-card {
                    padding: 2rem 1.5rem;
                }
            }

            /* Mensaje de error */
            .login-error {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                background-color: rgba(255, 55, 55, 0.1);
                border: 1.5px solid var(--rojo);
                border-radius: 8px;
                padding: 0.65rem 0.9rem;
                animation: shake 0.3s ease;
            }

            .login-error svg {
                flex-shrink: 0;
                width: 18px;
                height: 18px;
                fill: var(--rojo);
            }

            .login-error-text,
            .login-error ul {
                margin: 0;
                padding: 0;
                list-style: none;
                color: var(--rojo);
                font-size: 0.85rem;
                font-weight: 600;
            }

            @@keyframes shake {
                0%, 100% { transform: translateX(0); }
                25%       { transform: translateX(-5px); }
                75%       { transform: translateX(5px); }
            }
    </style>
</head>
<body>
    @RenderBody()
</body>
</html>