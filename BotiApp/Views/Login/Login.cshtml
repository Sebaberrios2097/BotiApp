@model BotiApp.Models.LoginViewModel
@{
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
    ViewData["Title"] = "Iniciar sesión";
}

<div class="login-wrapper">

    <!-- Panel de marca -->
    <div class="login-brand">
        <div class="brand-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
            </svg>
        </div>
        <h1>Botillería Cuatro Ases</h1>
    </div>

    <!-- Formulario -->
    <div class="login-card">
        <div>
            <h2>Bienvenido 👋</h2>
            <br />
            <p class="subtitle">Inicia sesión para continuar</p>
        </div>

        <form method="post" asp-controller="Login" asp-action="Login">
            @Html.AntiForgeryToken()

            <div style="display:flex; flex-direction:column; gap:1.1rem;">
                <div class="form-group">
                    <label for="usuario">Usuario</label>
                    <div class="input-wrapper">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z" />
                        </svg>
                        <input type="text" id="usuario" name="Usuario"
                               value="@Model?.Usuario"
                               placeholder="Ingresa tu usuario" autocomplete="username" required />
                    </div>
                </div>

                <div class="form-group">
                    <label for="clave">Contraseña</label>
                    <div class="input-wrapper">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M18 8h-1V6A5 5 0 0 0 7 6v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2zm-6 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm3.1-9H8.9V6a3.1 3.1 0 0 1 6.2 0v2z" />
                        </svg>
                        <input type="password" id="clave" name="Clave"
                               placeholder="Ingresa tu contraseña" autocomplete="current-password" required />
                    </div>
                </div>

                <div class="form-options">
                    <label>
                        <input type="checkbox" name="Recordar" @(Model?.Recordar == true ? "checked" : "") />
                        Recordarme
                    </label>
                    <a href="#">¿Olvidaste tu contraseña?</a>
                </div>

                @* Mensaje de error de credenciales *@
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="login-error">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                        </svg>
                        @Html.ValidationSummary(true, "", new { @class = "login-error-text" })
                    </div>
                }

                <button type="submit" class="btn-login">Iniciar sesión</button>
            </div>
        </form>
    </div>

</div>