@using Infraestructura.Entities.BotiApp
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Configuración del sistema";

    var tiposProducto = (ViewBag.TiposProducto as IEnumerable<ProTiposProductos>) ?? [];
    var marcas        = (ViewBag.Marcas        as IEnumerable<ProMarcas>)          ?? [];
    var metodosPago   = (ViewBag.MetodosPago   as IEnumerable<VenMetodosPago>)      ?? [];
}

<style>
    .config-page-title {
        font-size: 1.45rem;
        font-weight: 700;
        color: var(--color-secundario);
        margin-bottom: 0.25rem;
    }

    .config-page-subtitle {
        font-size: 0.88rem;
        color: var(--color-secundario);
        opacity: 0.55;
        margin-bottom: 1.75rem;
    }

    .config-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 1.5rem;
    }

    .config-card {
        background: var(--blanco);
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .config-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .config-card-title {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-size: 1rem;
        font-weight: 700;
        color: var(--color-secundario);
    }

    .config-card-title svg {
        width: 20px;
        height: 20px;
        fill: var(--color-primario);
        flex-shrink: 0;
    }

    .btn-add {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.45rem 0.9rem;
        background-color: var(--color-primario);
        color: var(--blanco);
        border: none;
        border-radius: 8px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
        white-space: nowrap;
    }

    .btn-add svg {
        width: 16px;
        height: 16px;
        fill: currentColor;
    }

    .btn-add:hover { background-color: #cf5f22; }

    .config-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88rem;
    }

    .config-table th {
        text-align: left;
        padding: 0.5rem 0.6rem;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: var(--color-primario);
        border-bottom: 2px solid #f0e8e0;
    }

    .config-table td {
        padding: 0.5rem 0.6rem;
        border-bottom: 1px solid #f5f0eb;
        vertical-align: middle;
    }

    .config-table tr:last-child td { border-bottom: none; }
    .config-table tr:hover td { background-color: #faf6f2; }

    .config-table .td-acciones {
        text-align: right;
        white-space: nowrap;
    }

    .btn-icon {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.3rem;
        border-radius: 6px;
        color: var(--color-secundario);
        opacity: 0.55;
        transition: opacity 0.2s, background-color 0.2s;
    }

    .btn-icon:hover { opacity: 1; background-color: #f0e8e0; }

    .btn-icon svg {
        width: 17px;
        height: 17px;
        fill: currentColor;
        display: block;
    }

    .btn-icon.danger:hover { background-color: #ffe0e0; color: var(--color-danger); }

    .badge-estado {
        display: inline-block;
        padding: 0.15rem 0.55rem;
        border-radius: 12px;
        font-size: 0.73rem;
        font-weight: 700;
    }

    .badge-estado.activo  { background: #e9f9ee; color: var(--color-success); }
    .badge-estado.inactivo { background: #fff0f0; color: var(--color-danger); }

    /* Modal inline */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.45);
        z-index: 500;
        align-items: center;
        justify-content: center;
    }

    .modal-overlay.open { display: flex; }

    .modal-box {
        background: var(--blanco);
        border-radius: 14px;
        padding: 1.75rem;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.25);
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
    }

    .modal-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--color-secundario);
    }

    .modal-input {
        width: 100%;
        padding: 0.7rem 0.9rem;
        border: 2px solid #e0d5cc;
        border-radius: 8px;
        font-size: 0.93rem;
        outline: none;
        transition: border-color 0.2s;
    }

    .modal-input:focus { border-color: var(--color-primario); }

    .modal-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }

    .btn-confirm {
        padding: 0.55rem 1.2rem;
        background-color: var(--color-primario);
        color: var(--blanco);
        border: none;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .btn-confirm:hover { background-color: #cf5f22; }

    .btn-cancel {
        padding: 0.55rem 1.1rem;
        background: transparent;
        border: 1.5px solid #ddd;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        color: var(--color-secundario);
        transition: border-color 0.2s;
    }

    .btn-cancel:hover { border-color: var(--color-secundario); }

    .toast-container {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 900;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .toast {
        padding: 0.75rem 1.1rem;
        border-radius: 10px;
        font-size: 0.87rem;
        font-weight: 600;
        color: var(--blanco);
        box-shadow: 0 4px 14px rgba(0,0,0,0.2);
        animation: slideIn 0.25s ease;
    }

    .toast.ok    { background-color: var(--color-success); }
    .toast.error { background-color: var(--color-danger); }

    @@keyframes slideIn {
        from { transform: translateX(60px); opacity: 0; }
        to   { transform: translateX(0);    opacity: 1; }
    }
</style>

<h1 class="config-page-title">Configuración del sistema</h1>
<p class="config-page-subtitle">Administra los catálogos base utilizados en el sistema.</p>

<div class="config-grid">

    <!-- ── TIPOS DE PRODUCTO ─────────────────────────────────────────────── -->
    <div class="config-card">
        <div class="config-card-header">
            <div class="config-card-title">
                <svg viewBox="0 0 24 24"><path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
                Tipos de Producto
            </div>
            <button class="btn-add" onclick="abrirModal('tipo', null, null)">
                <svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                Nuevo
            </button>
        </div>
        <table class="config-table" id="tabla-tipos">
            <thead>
                <tr><th>Nombre</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var t in tiposProducto)
                {
                    <tr id="tipo-@t.IdTipoProducto">
                        <td>@t.NombreTipoProducto</td>
                        <td class="td-acciones">
                            <button class="btn-icon" title="Editar" onclick="abrirModal('tipo', @t.IdTipoProducto, '@Html.Raw(t.NombreTipoProducto.Replace("'","\\'"  ))')">
                                <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm17.71-10.46a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                            </button>
                            <button class="btn-icon danger" title="Eliminar" onclick="eliminar('tipo', @t.IdTipoProducto)">
                                <svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zm13-15h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ── MARCAS ─────────────────────────────────────────────────────────── -->
    <div class="config-card">
        <div class="config-card-header">
            <div class="config-card-title">
                <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
                Marcas
            </div>
            <button class="btn-add" onclick="abrirModal('marca', null, null)">
                <svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                Nueva
            </button>
        </div>
        <table class="config-table" id="tabla-marcas">
            <thead>
                <tr><th>Nombre</th><th>Estado</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var m in marcas)
                {
                    <tr id="marca-@m.IdMarca">
                        <td>@m.NombreMarca</td>
                        <td>
                            <span class="badge-estado @(m.Estado ? "activo" : "inactivo")">
                                @(m.Estado ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="td-acciones">
                            <button class="btn-icon" title="Editar" onclick="abrirModal('marca', @m.IdMarca, '@Html.Raw(m.NombreMarca.Replace("'","\\'"  ))')">
                                <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm17.71-10.46a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                            </button>
                            <button class="btn-icon" title="@(m.Estado ? "Desactivar" : "Activar")" onclick="toggleMarca(@m.IdMarca)">
                                <svg viewBox="0 0 24 24"><path d="@(m.Estado ? "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z" : "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z")"/></svg>
                            </button>
                            <button class="btn-icon danger" title="Eliminar" onclick="eliminar('marca', @m.IdMarca)">
                                <svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zm13-15h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ── MÉTODOS DE PAGO ────────────────────────────────────────────────── -->
    <div class="config-card">
        <div class="config-card-header">
            <div class="config-card-title">
                <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/></svg>
                Métodos de Pago
            </div>
            <button class="btn-add" onclick="abrirModal('pago', null, null)">
                <svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                Nuevo
            </button>
        </div>
        <table class="config-table" id="tabla-pagos">
            <thead>
                <tr><th>Nombre</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var p in metodosPago)
                {
                    <tr id="pago-@p.IdMetodoPago">
                        <td>@p.NombreMetodoPago</td>
                        <td class="td-acciones">
                            <button class="btn-icon" title="Editar" onclick="abrirModal('pago', @p.IdMetodoPago, '@Html.Raw(p.NombreMetodoPago.Replace("'","\\'"  ))')">
                                <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm17.71-10.46a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                            </button>
                            <button class="btn-icon danger" title="Eliminar" onclick="eliminar('pago', @p.IdMetodoPago)">
                                <svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zm13-15h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<!-- ── MODAL ────────────────────────────────────────────────────────────── -->
<div class="modal-overlay" id="modal" onclick="cerrarModalSiOverlay(event)">
    <div class="modal-box">
        <div class="modal-title" id="modal-title">Nuevo registro</div>
        <input class="modal-input" id="modal-input" type="text" placeholder="Nombre" maxlength="100" />
        <div class="modal-actions">
            <button class="btn-cancel" onclick="cerrarModal()">Cancelar</button>
            <button class="btn-confirm" onclick="guardarModal()">Guardar</button>
        </div>
    </div>
</div>

<!-- ── TOAST ─────────────────────────────────────────────────────────────── -->
<div class="toast-container" id="toastContainer"></div>

@section Scripts {
<script>
    let modalTipo = null;
    let modalId   = null;

    function abrirModal(tipo, id, nombreActual) {
        modalTipo = tipo;
        modalId   = id;
        const titulos = { tipo: 'Tipo de Producto', marca: 'Marca', pago: 'Método de Pago' };
        document.getElementById('modal-title').textContent = (id ? 'Editar ' : 'Nuevo ') + titulos[tipo];
        document.getElementById('modal-input').value = nombreActual ?? '';
        document.getElementById('modal').classList.add('open');
        document.getElementById('modal-input').focus();
    }

    function cerrarModal() {
        document.getElementById('modal').classList.remove('open');
        modalTipo = null; modalId = null;
    }

    function cerrarModalSiOverlay(e) {
        if (e.target.id === 'modal') cerrarModal();
    }

    async function guardarModal() {
        const nombre = document.getElementById('modal-input').value.trim();
        if (!nombre) { mostrarToast('El nombre no puede estar vacío.', false); return; }

        const urls = {
            tipo:  modalId ? '/Configuracion/EditarTipoProducto'  : '/Configuracion/CrearTipoProducto',
            marca: modalId ? '/Configuracion/EditarMarca'          : '/Configuracion/CrearMarca',
            pago:  modalId ? '/Configuracion/EditarMetodoPago'     : '/Configuracion/CrearMetodoPago'
        };

        const body = modalId ? { Id: modalId, Nombre: nombre } : { Nombre: nombre };
        const res  = await post(urls[modalTipo], body);

        if (!res.ok) { mostrarToast(res.mensaje, false); return; }

        // Actualizar fila si edición, o agregar si creación
        if (modalId) {
            const row = document.getElementById(`${modalTipo}-${res.id}`);
            if (row) {
                row.querySelector('td').textContent = res.nombre;
                // marcas: actualizar badge si existe
                if (modalTipo === 'marca') {
                    const badge = row.querySelector('.badge-estado');
                    if (badge) badge.textContent = res.estado ? 'Activo' : 'Inactivo';
                }
            }
        } else {
            agregarFila(modalTipo, res);
        }

        mostrarToast('Guardado correctamente.', true);
        cerrarModal();
    }

    function agregarFila(tipo, res) {
        const tbodies = { tipo: '#tabla-tipos tbody', marca: '#tabla-marcas tbody', pago: '#tabla-pagos tbody' };
        const tbody = document.querySelector(tbodies[tipo]);

        let celdas = '';
        if (tipo === 'tipo') {
            celdas = `<td>${res.nombre}</td>
                      <td class="td-acciones">
                        <button class="btn-icon" onclick="abrirModal('tipo',${res.id},'${esc(res.nombre)}')" title="Editar"><svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm17.71-10.46a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg></button>
                        <button class="btn-icon danger" onclick="eliminar('tipo',${res.id})" title="Eliminar"><svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zm13-15h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg></button>
                      </td>`;
        } else if (tipo === 'marca') {
            celdas = `<td>${res.nombre}</td>
                      <td><span class="badge-estado activo">Activo</span></td>
                      <td class="td-acciones">
                        <button class="btn-icon" onclick="abrirModal('marca',${res.id},'${esc(res.nombre)}')" title="Editar"><svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm17.71-10.46a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg></button>
                        <button class="btn-icon" onclick="toggleMarca(${res.id})" title="Desactivar"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg></button>
                        <button class="btn-icon danger" onclick="eliminar('marca',${res.id})" title="Eliminar"><svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zm13-15h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg></button>
                      </td>`;
        } else {
            celdas = `<td>${res.nombre}</td>
                      <td class="td-acciones">
                        <button class="btn-icon" onclick="abrirModal('pago',${res.id},'${esc(res.nombre)}')" title="Editar"><svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm17.71-10.46a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg></button>
                        <button class="btn-icon danger" onclick="eliminar('pago',${res.id})" title="Eliminar"><svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zm13-15h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg></button>
                      </td>`;
        }

        const tr = document.createElement('tr');
        tr.id = `${tipo}-${res.id}`;
        tr.innerHTML = celdas;
        tbody.appendChild(tr);
    }

    async function eliminar(tipo, id) {
        if (!confirm('¿Estás seguro de que deseas eliminar este registro?')) return;

        const urls = {
            tipo:  '/Configuracion/EliminarTipoProducto',
            marca: '/Configuracion/EliminarMarca',
            pago:  '/Configuracion/EliminarMetodoPago'
        };

        const res = await post(urls[tipo], { Id: id });
        if (res.ok) {
            document.getElementById(`${tipo}-${id}`)?.remove();
            mostrarToast('Eliminado correctamente.', true);
        } else {
            mostrarToast(res.mensaje, false);
        }
    }

    async function toggleMarca(id) {
        const res = await post('/Configuracion/ToggleMarca', { Id: id });
        if (!res.ok) { mostrarToast(res.mensaje, false); return; }

        const row   = document.getElementById(`marca-${id}`);
        const badge = row?.querySelector('.badge-estado');
        if (badge) {
            badge.textContent = res.estado ? 'Activo' : 'Inactivo';
            badge.className   = `badge-estado ${res.estado ? 'activo' : 'inactivo'}`;
        }
        mostrarToast(res.estado ? 'Marca activada.' : 'Marca desactivada.', true);
    }

    async function post(url, data) {
        const tok = document.cookie.split(';').map(c => c.trim()) || [];
        const headers = {
            'Content-Type': 'application/json',
            'RequestVerificationToken': getToken()
        };
        const resp = await fetch(url, { method: 'POST', headers, body: JSON.stringify(data) });
        return resp.json();
    }

    function getToken() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }

    function esc(s) { return s.replace(/'/g, "\\'"); }

    function mostrarToast(msg, ok) {
        const c = document.getElementById('toastContainer');
        const t = document.createElement('div');
        t.className = `toast ${ok ? 'ok' : 'error'}`;
        t.textContent = msg;
        c.appendChild(t);
        setTimeout(() => t.remove(), 3500);
    }
</script>

@* Token antiforgery oculto para AJAX *@
<form id="af-form">@Html.AntiForgeryToken()</form>
}
